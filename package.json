{
  "name": "pi-prompt-title",
  "version": "0.0.0",
  "description": "A Pi extension seam for asynchronous session titles",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run test/extension.test.ts test/package.test.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "check": "npm run typecheck && npm test && npm run smoke"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@types/node": "24.12.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
