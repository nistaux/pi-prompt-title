{
  "name": "pi-prompt-title",
  "version": "0.0.0",
  "description": "A Pi extension seam for asynchronous session titles",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run --dir test",
    "test:unit": "vitest run test/configuration.test.ts test/extension.test.ts test/package.test.ts",
    "test:integration": "vitest run test/sdk-integration.test.ts",
    "validate:oauth": "vitest run validation/oauth.test.ts",
    "validate:quality": "vitest run validation/quality.test.ts",
    "validate:review": "vitest run validation/review.test.ts",
    "validate:reset": "vitest run validation/reset.test.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "check": "npm run typecheck && npm test && npm run verify:package && npm run smoke"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@types/node": "24.12.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
